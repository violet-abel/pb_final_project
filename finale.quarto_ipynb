    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Relationship: Health Spending vs Maternal Mortality\n",
        "\n",
        "## Row {height=\"40%\"}\n",
        "\n",
        "### Column {width=\"60%\"}"
      ],
      "id": "f09dfe3d"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "fig_bubble.show()"
